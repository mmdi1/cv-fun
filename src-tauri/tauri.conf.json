{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FunCV",
  "version": "0.1.0",
  "identifier": "com.nfun.cv",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "FunCV",
        "width": 960,
        "height": 640,
        "resizable": true,
        "decorations": false,
        "minimizable": false,
        "maximizable": false,
        "closable": true,
        "center": true,
        "visible": true,
        "shadow": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
