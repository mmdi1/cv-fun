{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test:unit": "node --no-warnings --experimental-strip-types --test \"src/features/**/*.test.ts\"",
    "build:dev": "vue-tsc && vite build --minify false --mode development",
    "build": "vue-tsc && vite build --mode production",
    "preview": "vite preview"
  },
  "dependencies": {
    "@wailsio/runtime": "latest",
    "vue": "^3.2.45"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^4.9.3",
    "vite": "^8.0.5",
    "vue-tsc": "^1.0.11"
  }
}
